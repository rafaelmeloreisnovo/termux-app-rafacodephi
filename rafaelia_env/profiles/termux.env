# RAFAELIA :: Termux host toolchain profile
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

export CC=clang
export CXX=clang++
export LD=ld.lld
export AR=llvm-ar
export NM=llvm-nm
export OBJCOPY=llvm-objcopy
export OBJDUMP=llvm-objdump
export STRIP=llvm-strip
export RANLIB=llvm-ranlib

# stable flags (avoid implicit vectorization / hidden calls)
export CFLAGS_COMMON='-O2 -Wall -Wextra'
export CFLAGS_FREESTANDING='-ffreestanding -fno-builtin -nostdlib -fno-stack-protector -fno-builtin-memcpy -fno-builtin-memset -fno-vectorize -fno-slp-vectorize'
