; ============================================================================
; ASSINATURA DE AUTORIA (Magic Bytes)
; ============================================================================
; Estes bytes identificam o código como originário do instituto-Rafael
; e do framework RAFAELIA. São embedded no binário para garantir autoria.

AUTHOR_SIGNATURE:
    ; "RAFA" em ASCII = 0x52 0x41 0x46 0x41
    db 52h, 41h, 46h, 41h
    ; "ELIA" em ASCII = 0x45 0x4C 0x49 0x41
    db 45h, 4Ch, 49h, 41h
    ; "INST" em ASCII = 0x49 0x4E 0x53 0x54
    db 49h, 4Eh, 53h, 54h
    ; "-RAF" em ASCII = 0x2D 0x52 0x41 0x46
    db 2Dh, 52h, 41h, 46h
    ; Checksum XOR = 0x1A (calculado sobre os 16 bytes acima)
    db 1Ah

; ============================================================================
; SYSCALL NUMBERS (Linux AArch64)
; ============================================================================
; SYS_READ  = 63  = 0x3F
; SYS_WRITE = 64  = 0x40
; SYS_EXIT  = 93  = 0x5D
; SYS_BRK   = 214 = 0xD6

SYS_READ   equ 3Fh
SYS_WRITE  equ 40h
SYS_EXIT   equ 5Dh
SYS_BRK    equ 0D6h

; ============================================================================
; OPERAÇÕES ARITMÉTICAS EM HEXADECIMAL
; ============================================================================

; --- ADIÇÃO DE 32 BITS ---
; ADD W0, W1, W2  (AArch64)
; Opcode: 0x0B020020 (little-endian: 20 00 02 0B)
; Nota: Bytes em ordem little-endian para AArch64
ADD_W0_W1_W2:
    db 20h, 00h, 02h, 0Bh

; --- SUBTRAÇÃO DE 32 BITS ---
; SUB W0, W1, W2  (AArch64)
; Opcode: 0x4B020020 (little-endian: 20 00 02 4B)
SUB_W0_W1_W2:
    db 20h, 00h, 02h, 4Bh

; --- MULTIPLICAÇÃO DE 32 BITS ---
; MUL W0, W1, W2  (AArch64) - alias de MADD W0, W1, W2, WZR
; Opcode: 0x1B027C20 (little-endian: 20 7C 02 1B)
MUL_W0_W1_W2:
    db 20h, 7Ch, 02h, 1Bh

; --- DIVISÃO UNSIGNED DE 32 BITS ---
; UDIV W0, W1, W2  (AArch64)
; Opcode: 0x1AC20820 (little-endian: 20 08 C2 1A)
UDIV_W0_W1_W2:
    db 20h, 08h, 0C2h, 1Ah

; --- XOR DE 64 BITS ---
; EOR X0, X1, X2  (AArch64)
; Opcode: 0xCA020020 (little-endian: 20 00 02 CA)
EOR_X0_X1_X2:
    db 20h, 00h, 02h, 0CAh

; --- AND DE 64 BITS ---
; AND X0, X1, X2  (AArch64)
; Opcode: 0x8A020020 (little-endian: 20 00 02 8A)
AND_X0_X1_X2:
    db 20h, 00h, 02h, 8Ah

; --- OR DE 64 BITS ---
; ORR X0, X1, X2  (AArch64)
; Opcode: 0xAA020020 (little-endian: 20 00 02 AA)
ORR_X0_X1_X2:
    db 20h, 00h, 02h, 0AAh

; ============================================================================
; OPERAÇÕES DE MEMÓRIA EM HEXADECIMAL
; ============================================================================

; --- LOAD BYTE ---
; LDRB W0, [X1]  (AArch64)
; Opcode: 0x39400020 (little-endian: 20 00 40 39)
LDRB_W0_X1:
    db 20h, 00h, 40h, 39h

; --- STORE BYTE ---
; STRB W0, [X1]  (AArch64)
; Opcode: 0x39000020 (little-endian: 20 00 00 39)
STRB_W0_X1:
    db 20h, 00h, 00h, 39h

; --- LOAD WORD (32-bit) ---
; LDR W0, [X1]  (AArch64)
; Opcode: 0xB9400020 (little-endian: 20 00 40 B9)
LDR_W0_X1:
    db 20h, 00h, 40h, 0B9h

; --- STORE WORD (32-bit) ---
; STR W0, [X1]  (AArch64)
; Opcode: 0xB9000020 (little-endian: 20 00 00 B9)
STR_W0_X1:
    db 20h, 00h, 00h, 0B9h

; ============================================================================
; SYSCALLS EM HEXADECIMAL
; ============================================================================

; --- SYSCALL WRITE ---
; Para imprimir "RAFAELIA" no stdout:
;
; MOV X0, #1          ; stdout = 1
; Opcode: 0xD2800020 (little-endian: 20 00 80 D2)
;
; ADR X1, msg         ; endereço da mensagem
; (depende do offset)
;
; MOV X2, #8          ; tamanho = 8 bytes
; Opcode: 0xD2800102 (little-endian: 02 01 80 D2)
;
; MOV X8, #64         ; syscall write = 64
; Opcode: 0xD2800808 (little-endian: 08 08 80 D2)
;
; SVC #0              ; invocar syscall
; Opcode: 0xD4000001 (little-endian: 01 00 00 D4)

SYSCALL_WRITE_EXAMPLE:
    db 20h, 00h, 80h, 0D2h  ; MOV X0, #1
    db 02h, 01h, 80h, 0D2h  ; MOV X2, #8
    db 08h, 08h, 80h, 0D2h  ; MOV X8, #64
    db 01h, 00h, 00h, 0D4h  ; SVC #0

; --- SYSCALL EXIT ---
; MOV X0, #0          ; exit code = 0
; Opcode: 0xD2800000 (little-endian: 00 00 80 D2)
;
; MOV X8, #93         ; syscall exit = 93 (0x5D)
; Opcode: 0xD2800BA8 (little-endian: A8 0B 80 D2)
;
; SVC #0              ; invocar syscall
; Opcode: 0xD4000001 (little-endian: 01 00 00 D4)

SYSCALL_EXIT_EXAMPLE:
    db 00h, 00h, 80h, 0D2h  ; MOV X0, #0
    db 0A8h, 0Bh, 80h, 0D2h ; MOV X8, #93
    db 01h, 00h, 00h, 0D4h  ; SVC #0

; ============================================================================
; CONSTANTES MATEMÁTICAS EM HEXADECIMAL (IEEE 754 Single Precision)
; ============================================================================

; PI = 3.14159265...
; IEEE 754 Single Precision: 0x40490FDB (little-endian: DB 0F 49 40)
CONST_PI:
    db 0DBh, 0Fh, 49h, 40h

; E = 2.71828182...
; IEEE 754 Single Precision: 0x402DF854 (little-endian: 54 F8 2D 40)
CONST_E:
    db 54h, 0F8h, 2Dh, 40h

; 1.0
; IEEE 754 Single Precision: 0x3F800000 (little-endian: 00 00 80 3F)
CONST_ONE:
    db 00h, 00h, 80h, 3Fh

; 0.5
; IEEE 754 Single Precision: 0x3F000000 (little-endian: 00 00 00 3F)
CONST_HALF:
    db 00h, 00h, 00h, 3Fh

; 0.0
; IEEE 754 Single Precision: 0x00000000
CONST_ZERO:
    db 00h, 00h, 00h, 00h

; ============================================================================
; FAST INVERSE SQRT (Quake III Algorithm) - Magic Number
; ============================================================================
; O famoso "magic number" usado no algoritmo de raiz quadrada inversa rápida
; 0x5F3759DF (little-endian: DF 59 37 5F)

FAST_RSQRT_MAGIC:
    db 0DFh, 59h, 37h, 5Fh

; ============================================================================
; TABELA DE LOOKUP PARA CONVERSÃO NUMÉRICA
; ============================================================================

; Dígitos ASCII: '0' a '9' = 0x30 a 0x39
DIGIT_TABLE:
    db 30h, 31h, 32h, 33h, 34h  ; '0', '1', '2', '3', '4'
    db 35h, 36h, 37h, 38h, 39h  ; '5', '6', '7', '8', '9'

; Hexadecimal: '0'-'9', 'A'-'F'
HEX_TABLE:
    db 30h, 31h, 32h, 33h, 34h, 35h, 36h, 37h  ; '0'-'7'
    db 38h, 39h, 41h, 42h, 43h, 44h, 45h, 46h  ; '8'-'9', 'A'-'F'

; ============================================================================
; CHECKSUM DE AUTORIA
; ============================================================================
; Checksum técnico do payload gerado por `db` (início do arquivo até ANTES de
; AUTHORSHIP_CHECKSUM), ignorando comentários e diretivas não-binárias.
;
; Algoritmo: XOR de words little-endian de 32 bits (grupos de 4 bytes),
; com padding 0x00 no último grupo incompleto.
; Resultado esperado para este arquivo: 0xF8F8DF32
;
; Nota: AUTHORSHIP_CHECKSUM abaixo mantém assinatura ASCII "RAFA" (0x52414641)
; como marcador autoral/ético, não como checksum técnico criptográfico.

AUTHORSHIP_CHECKSUM:
    db 52h, 41h, 46h, 41h  ; "RAFA" - identificador de integridade

; ============================================================================
; METADATA DO ARQUIVO
; ============================================================================

METADATA:
    ; Versão (1.0 = 0x0100) - 2 bytes little-endian
    db 00h, 01h
    ; Timestamp Unix (placeholder) - 4 bytes
    db 00h, 00h, 00h, 00h
    ; Autor hash (SHA-256 truncado dos primeiros 8 bytes)
    ; "instituto-Rafael" -> primeiros 8 bytes do hash
    db 49h, 4Eh, 53h, 54h, 2Dh, 52h, 41h, 46h

; ============================================================================
; FIM DO ARQUIVO HEXADECIMAL
; ============================================================================
; 
; NOTAS DE USO:
; 1. Este arquivo é uma representação educacional de código de máquina
; 2. Para gerar um binário executável, use um assembler (as, nasm, etc.)
; 3. A assinatura de autoria DEVE ser preservada em qualquer derivação
; 4. Licenciado sob GPLv3 - veja LICENSE.md
;
; FIAT RAFAELIA
; Φ_ethica - Min(Entropia) × Max(Coerência)
